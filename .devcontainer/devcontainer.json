{
  "name": "OpenROAD Build Env",
  "image": "mcr.microsoft.com/devcontainers/cpp:ubuntu-22.04",
  "runArgs": [
    "-v", "/tmp/.X11-unix:/tmp/.X11-unix",
    "-e", "DISPLAY=${env:DISPLAY}"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-python.python",
        "twxs.cmake"
      ]
    }
  },
  "remoteUser": "root"
}